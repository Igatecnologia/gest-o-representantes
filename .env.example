# Segredo para assinar JWT — OBRIGATORIO minimo 32 caracteres
# Gere com: openssl rand -base64 32
AUTH_SECRET=troque-para-um-segredo-aleatorio-com-32-chars-ou-mais

# Banco de dados
# Local (desenvolvimento):
DATABASE_URL=file:./data.db

# Turso (producao):
# DATABASE_URL=libsql://seu-banco.turso.io
# DATABASE_AUTH_TOKEN=seu-token-turso

# ─── Seed (npm run db:seed) ───────────────────────────────────
# OBRIGATORIO:
ADMIN_PASSWORD=SuaSenhaForte123!
# Opcionais:
# ADMIN_EMAIL=admin@iga.com.br
# ADMIN_NAME=Administrador IGA

# Representantes (opcionais):
# REP1_EMAIL=joao@empresa.com
# REP1_PASSWORD=SenhaDoJoao123!
# REP1_NAME=João Silva
# REP1_PHONE=(11) 99999-0001
# REP1_COMMISSION=10
